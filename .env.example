# Operator portal
# Secret password to access /operator. Keep this secure.
VITE_OPERATOR_PASSWORD=

# AI provider (currently only "openrouter" is supported)
VITE_AI_PROVIDER=openrouter

# OpenRouter API key from https://openrouter.ai/keys
# Required for AI features: Strategy AI search, pitch generation, live insights
VITE_OPENROUTER_API_KEY=

# OpenRouter model to use. Recommended: anthropic/claude-haiku-4.5
# See https://openrouter.ai/models for options
VITE_OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Fallback model used when primary model returns 429 rate-limit.
# Leave empty to disable fallback. Costs apply per OpenRouter pricing.
VITE_OPENROUTER_FALLBACK_MODEL=

# Demo mode — when "true", AI calls return canned mock responses
# instead of hitting the real API. Useful for screen recordings,
# demos, and avoiding burning credits during walkthroughs.
VITE_AI_DEMO_MODE=false
